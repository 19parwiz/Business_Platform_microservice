# HTTP Server Configuration
HTTP_PORT=8001
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_MAX_HEADER_BYTES=1048576
GIN_MODE=release

# PostgreSQL (psql: psql -h localhost -p 5432 -U postgres -d flower_shop)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flower_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=54321
POSTGRES_SSL_MODE=disable

# gRPC server configuration
GRPC_PORT=4001
GRPC_TIMEOUT=10h

# Use 127.0.0.1 so Windows does not prefer [::1] (IPv6) when Kafka listens on IPv4.
# Omit this line entirely to run without Kafka (consumer disabled).
BROKERS=127.0.0.1:9092
