# PostgreSQL only (psql / pgAdmin). No MongoDB.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flower_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSL_MODE=disable

GRPC_PORT=50052
HTTP_PORT=8082

# Kafka (Docker Compose publishes 9092). Use 127.0.0.1 on Windows if localhost resolves to IPv6 first.
BROKERS=127.0.0.1:9092
